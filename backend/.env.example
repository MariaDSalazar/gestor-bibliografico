# Variables de entorno del Gestor Bibliográfico.
# Cópialo a `.env` y ajusta. Hoy el backend las lee de variables de entorno del
# sistema (os.environ); si más adelante se añade python-dotenv, se cargará este archivo.

# --- Backend ---
# Email de contacto para el "polite pool" de Crossref/doi.org (se envía en el User-Agent).
BIBLIO_EMAIL=cojeda@bestlinesoft.com

# Carpeta donde se guardan la base SQLite y los PDFs. Por defecto: ~/.gestor-bibliografico
# BIBLIO_DATA=D:\Cursos\bibliografia\backend\data
